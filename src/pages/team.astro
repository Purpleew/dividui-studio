---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const members = [
  { name: 'Sara Ferrari', role: 'Creative Director' },
  { name: 'Marco Rossi', role: 'Lead Designer' },
  { name: 'Giulia Bianchi', role: 'Frontend Developer' },
  { name: 'Luca Conti', role: 'Brand Strategist' },
  { name: 'Elena Mori', role: 'Motion Designer' },
  { name: 'Andrea Ricci', role: 'Full Stack Developer' },
];
---

<Layout
  title="Team — Dividui® Studio"
  description="The independent minds behind Dividui® Studio. Designers, developers, strategists — people who chose craft over conformity."
>
  <section class="pt-40 pb-24">
    <div class="container">
      <p class="font-mono text-xs uppercase tracking-[0.3em] text-muted-foreground mb-4">/ The team</p>
      <h1 class="font-light tracking-tighter text-[clamp(3rem,8vw,7rem)] leading-none mb-20">Team</h1>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-16">
        {members.map(m => (
          <div class="group">
            <div class="aspect-[3/4] overflow-hidden mb-5" style="background-color: color-mix(in oklab, var(--color-foreground) 5%, transparent)">
              <div class="w-full h-full flex items-end p-6">
                <span class="font-light text-4xl" style="color: color-mix(in oklab, var(--color-foreground) 10%, transparent)">{m.name.charAt(0)}</span>
              </div>
            </div>
            <p class="font-medium text-lg leading-tight">{m.name}</p>
            <p class="text-sm text-muted-foreground mt-1">{m.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
