---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { value: '2026', label: 'Founded' },
  { value: '40+', label: 'Active freelances' },
  { value: '12+', label: 'Projects delivered' },
  { value: '100%', label: 'Custom work' },
];
---

<Layout
  title="About — Dividui® Studio"
  description="Dividui® Studio is born from the idea that creative work is always a collective act. An independent studio for freelances who believe in craft."
>
  <section class="pt-40 pb-24">
    <div class="container">
      <p class="font-mono text-xs uppercase tracking-[0.3em] text-muted-foreground mb-4">/ Our story</p>
      <h1 class="font-light tracking-tighter text-[clamp(3rem,8vw,7rem)] leading-none mb-20">About</h1>

      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-2xl md:text-3xl font-light leading-snug tracking-tight">
            Dividui® Studio is born from the idea that creative work is always a collective act.
          </p>
        </div>
        <div class="space-y-6 leading-relaxed text-muted-foreground">
          <p>
            We are an independent creative studio for freelances who believe in the value of craft, care, and authentic collaboration. Not a marketplace, not an agency — a shared space where talents meet and projects take form.
          </p>
          <p>
            We work with professionals from design, communication, development, and strategy. People who chose independence without giving up community.
          </p>
        </div>
      </div>

      <div class="mt-24 grid grid-cols-2 md:grid-cols-4 gap-8 border-t border-border pt-16">
        {stats.map(s => (
          <div>
            <p class="font-light text-5xl tracking-tighter">{s.value}</p>
            <p class="text-sm text-muted-foreground mt-2">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
