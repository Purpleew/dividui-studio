---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import QualitySection from '../components/QualitySection.astro';
import QualityPromise from '../components/QualityPromise.astro';
import EditorialGrid from '../components/EditorialGrid.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const marqueeItems = [
  { label: 'Dividui® — Studio creativo indipendente', href: '#' },
  { label: 'Where dialogue creates value', href: '#' },
  { label: 'Independent minds. Shared craft.', href: '#' },
];
---

<Layout
  title="Dividui® Studio"
  description="Independent creative studio born from the collaboration of freelances. Where dialogue creates value."
>
  <Hero />

  <section class="py-24 md:py-40 border-b border-border">
    <div class="container">
      <a href="mailto:hello@dividui.studio" class="group inline-block font-light tracking-tighter leading-none text-[clamp(2rem,6vw,6rem)] hover:opacity-40 transition-opacity">
        hello@dividui.studio <span aria-hidden class="transition-transform group-hover:translate-x-2 inline-block">&rarr;</span>
      </a>
    </div>
  </section>

  <Marquee items={marqueeItems} />
  <QualitySection />
  <EditorialGrid />
  <QualityPromise />
  <Marquee items={marqueeItems} reverse />
  <ContactForm />
  <Footer />
</Layout>
