---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contatti — Dividui® Studio"
  description="Scrivici. Entra nel network, inizia una collaborazione, o semplicemente salutaci."
>
  <section class="pt-40 pb-8">
    <div class="container">
      <h1 class="font-light tracking-tighter text-[clamp(3rem,8vw,7rem)] leading-none mb-16">Contatti</h1>

      <p class="text-lg text-muted-foreground max-w-xl mb-10 leading-relaxed">Ti va di fare due chiacchiere con noi? Che tu stia cercando un partner creativo, un'idea fuori dagli schemi o semplicemente voglia conoscerci meglio, qui sei nel posto giusto.</p>

      <div class="flex flex-col gap-4 mb-10">
        <a href="mailto:hello@dividui.studio" class="font-light tracking-tighter text-[clamp(1.5rem,4vw,3.5rem)] leading-none hover:opacity-40 transition-opacity">
          hello@dividui.studio
        </a>
      </div>

      <a href="https://calendar.notion.so/meet/sara-ferrari/dividui-studio"
        target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 h-12 rounded-full text-sm font-medium hover:opacity-90 transition-opacity mb-16"
        style="background-color: var(--color-foreground); color: var(--color-background)">
        Prenota un appuntamento &rarr;
      </a>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>
