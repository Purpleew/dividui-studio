---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contatti — Dividui® Studio"
  description="Scrivici. Entra nel network, inizia una collaborazione, o semplicemente salutaci."
>
  <section class="pt-40 pb-8">
    <div class="container">
      <h1 class="font-light tracking-tighter text-[clamp(3rem,8vw,7rem)] leading-none mb-16">Contatti</h1>

      <p class="text-lg text-muted-foreground max-w-md mb-10 leading-relaxed">Nessuna call infinita, nessun brief da compilare. Scrivici un messaggio — rispondiamo sempre.</p>

      <div class="flex flex-col gap-4 mb-16">
        <a href="mailto:hello@dividui.studio" class="font-light tracking-tighter text-[clamp(1.5rem,4vw,3.5rem)] leading-none hover:opacity-40 transition-opacity">
          hello@dividui.studio
        </a>
        <a href="tel:+393454452660" class="font-light tracking-tighter text-[clamp(1.5rem,4vw,3.5rem)] leading-none hover:opacity-40 transition-opacity">
          +39 345 445 2660
        </a>
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>
