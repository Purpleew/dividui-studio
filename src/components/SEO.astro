---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
}

const {
  title = 'Dividui Studio',
  description = 'Una rete di freelance verticali che costruisce identità, esperienze digitali e contenuti. Diamo forma ai brand e li rendiamo impossibili da ignorare.',
  image = '/social-card.jpg',
  canonical = Astro.url.href,
  noindex = false,
  type = 'website',
} = Astro.props;

const siteName = 'Dividui Studio — Studio creativo indipendente';
const fullTitle = title === 'Dividui Studio' ? siteName : `${title} | Dividui Studio`;
const imageURL = new URL(image, Astro.site).toString();
---

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="keywords" content="studio creativo, branding, identità visiva, web design, freelance, advertising, social media, video, collettivo creativo, Milano, Italia" />
<meta name="author" content="Dividui Studio" />
<link rel="canonical" href={canonical} />

<!-- Robots -->
{noindex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-image-preview:large" />
}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Dividui Studio — Studio creativo indipendente" />
<meta property="og:site_name" content="Dividui Studio" />
<meta property="og:locale" content="it_IT" />
<meta property="og:locale:alternate" content="en_US" />

<!-- X (Twitter) -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:domain" content="dividui.studio" />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content="Dividui Studio — Studio creativo indipendente" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Dividui Studio",
  "alternateName": "Dividui",
  "url": "https://dividui.studio",
  "logo": "https://dividui.studio/logo.svg",
  "description": "Una rete di freelance verticali che costruisce identità, esperienze digitali e contenuti. Diamo forma ai brand e li rendiamo impossibili da ignorare.",
  "slogan": "Più individui. Un solo brand.",
  "foundingDate": "2026",
  "areaServed": ["Italy", "Europe"],
  "knowsLanguage": ["it", "en"],
  "knowsAbout": ["Branding", "Identità visiva", "Web Design", "Sviluppo web", "Social Media", "Video", "Advertising", "Creative Direction", "Content Strategy"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servizi creativi",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Branding & Identità visiva" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Esperienze digitali & Web" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Video & Contenuti" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Social Media & Advertising" } }
    ]
  },
  "sameAs": [
    "https://www.instagram.com/dividui/",
    "https://www.linkedin.com/company/dividui/"
  ]
})} />