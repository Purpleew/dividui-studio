---
// src/components/SplineKeyboard.astro
---

<div class="spline-keyboard-wrapper">
  <div class="spline-loader" id="splineLoader"></div>

  <script type="module" src="https://unpkg.com/@splinetool/viewer@1.12.97/build/spline-viewer.js"></script>
  <spline-viewer
    id="splineKeyboard"
    url="https://prod.spline.design/WTHxxtKHSQbzd3fp/scene.splinecode"
  ></spline-viewer>
</div>

<script>
  type KeyAction = 'writePrompt' | 'topic' | 'remix' | 'nextIdea' | 'send' | 'save' | 'heart' | 'aiMode' | 'reset';

  function dispatchKeyPress(action: KeyAction) {
    window.dispatchEvent(new CustomEvent('dividui:keypress', {
      detail: { action }
    }));
  }

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.code === 'Space') {
      e.preventDefault();
      dispatchKeyPress('writePrompt');
    } else if (e.code === 'Enter') {
      e.preventDefault();
      dispatchKeyPress('nextIdea');
    } else if (e.code === 'Period') {
      e.preventDefault();
      dispatchKeyPress('reset');
    }
  });

  // Spline object → action mapping
  const OBJECT_MAP: Record<string, KeyAction> = {
    'write':  'writePrompt',
    'prompt': 'writePrompt',
    'combo':  'writePrompt',
    'space':  'writePrompt',
    'next':   'nextIdea',
    'enter':  'nextIdea',
    'topic':  'topic',
    'remix':  'remix',
    'send':   'send',
    'save':   'save',
    'heart':  'heart',
    'love':   'heart',
    'reset':  'reset',
    'punto':  'reset',
    'ai':     'aiMode',
  };

  function handleSplineClick(name: string) {
    for (const [key, action] of Object.entries(OBJECT_MAP)) {
      if (name.includes(key)) {
        dispatchKeyPress(action);
        return;
      }
    }
    if (name) dispatchKeyPress('writePrompt');
  }

  // Wait for spline-viewer to load, then attach events
  function attachSplineEvents() {
    const viewer = document.getElementById('splineKeyboard') as any;
    const loader = document.getElementById('splineLoader');
    if (!viewer) return;

    viewer.addEventListener('load', () => {
      if (loader) loader.style.display = 'none';

      // Try both known runtime paths
      const app = viewer._spline ?? viewer.spline ?? viewer.runtime;
      if (!app) {
        console.warn('[Spline] runtime not found after load');
        return;
      }

      // Activate the "sara" camera if present
      try {
        const saraCamera = app.findObjectByName?.('sara') ?? app.findObjectByName?.('Sara');
        if (saraCamera) {
          app.setActiveCamera?.(saraCamera);
        }
      } catch (e) {
        // camera not found or API unavailable — no-op
      }

      app.addEventListener('mouseDown', (e: any) => {
        const name: string = e?.target?.name?.toLowerCase() ?? '';
        handleSplineClick(name);
      });

      app.addEventListener('keyDown', (e: any) => {
        const name: string = e?.target?.name?.toLowerCase() ?? '';
        handleSplineClick(name);
      });
    });
  }

  // Attach after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', attachSplineEvents);
  } else {
    attachSplineEvents();
  }
</script>

<style>
  .spline-keyboard-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    background: transparent;
  }

  spline-viewer {
    width: 100%;
    height: 100%;
    display: block;
    background: transparent;
    --spline-viewer-bg: transparent;
  }

  .spline-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    z-index: 1;
    pointer-events: none;
  }
</style>
