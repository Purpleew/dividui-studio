---
import Badge from './Badge.astro';

const capabilities = [
  { label: 'Brand Identity', n: '01' },
  { label: 'Product Design', n: '02' },
  { label: 'Web Development', n: '03' },
  { label: 'Motion & Visual', n: '04' },
  { label: 'Content & Copy', n: '05' },
  { label: 'Strategy', n: '06' },
];
---
<section id="work" class="py-24 md:py-40 border-b border-border">
  <div class="container">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <Badge>01 Disciplines</Badge>
        <h2 class="mt-6 text-5xl md:text-7xl leading-[0.95] tracking-tight text-balance">
          Craft over output.
          <span class="block text-muted-foreground">People chosen for what they know.</span>
        </h2>
      </div>

      <div class="lg:col-span-7 lg:pl-12 lg:border-l border-border">
        <p class="text-2xl md:text-3xl leading-snug text-balance mb-12">
          Dividui brings together independent talents and projects that deserve care. Every collaboration is born from real skill and shared intention.
        </p>

        <ul class="divide-y divide-border">
          {capabilities.map(c => (
            <li class="group flex items-center justify-between py-5 cursor-pointer">
              <div class="flex items-baseline gap-6">
                <span class="font-mono text-xs text-muted-foreground">{c.n}</span>
                <span class="text-2xl md:text-3xl">{c.label}</span>
              </div>
              <span class="text-2xl transition-transform group-hover:translate-x-2">&rarr;</span>
            </li>
          ))}
        </ul>

        <a href="#" class="mt-12 inline-flex items-center gap-3 text-sm font-medium border-b pb-1 transition-colors" style="border-color: color-mix(in oklab, var(--color-foreground) 30%, transparent)">
          Explore all disciplines <span aria-hidden>&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>
