---
export interface Props {
  items: Array<{ label: string; href: string }>;
  reverse?: boolean;
}
const { items, reverse = false } = Astro.props;
---
<div class="relative overflow-hidden border-y border-border py-8 pause-on-hover">
  <div class={`marquee-track flex gap-12 whitespace-nowrap w-max ${reverse ? 'animate-marquee-reverse' : 'animate-marquee'}`}>
    {[...items, ...items].map((item, i) => (
      <a href={item.href} class="group flex items-center gap-6 text-3xl md:text-5xl font-light tracking-tight transition-colors" style="color: inherit" onmouseover="this.style.color='var(--color-accent)'" onmouseout="this.style.color='inherit'">
        <span style="color: var(--color-accent)">&#9733;</span>
        {item.label}
      </a>
    ))}
  </div>
</div>
