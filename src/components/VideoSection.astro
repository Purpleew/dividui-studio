---
interface Props {
  src?: string;
  poster?: string;
}
const { src, poster } = Astro.props;
---
<section style="position:relative;width:100%;aspect-ratio:16/9;overflow:hidden;background:#000;">
  {src ? (
    <video
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
      src={src}
      poster={poster}
      autoplay
      muted
      loop
      playsinline
    />
  ) : (
    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#555;">
      <span style="font-size:0.75rem;letter-spacing:0.2em;text-transform:uppercase;">Video</span>
    </div>
  )}
</section>
